const mongoose = require('mongoose');

const exerciseSchema = new mongoose.Schema(
  {
    name: {
      type: String,
      required: true,
      trim: true,
      lowercase: true,
      maxlength: 100,
      index: true,
    },

    bodyPartId: {
      type: String,
      required: true,
      trim: true,
      lowercase: true,
      index: true,
    },

    image: {
      type: String,
      required: true,
      trim: true,
    },

    instructions: {
      type: [String],

      default: [],

      set: (instructions) =>
        instructions.map((item) =>
          item.trim()
        ),
    },
  },
  {
    timestamps: true,
  }
);

module.exports = mongoose.model(
  'Exercise',
  exerciseSchema
);